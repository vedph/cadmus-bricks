{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MolDatabase": "Host=localhost;Database=mol;Username=postgres;Password=postgres"
  },
  "Mol": {
    "Provider": "PostgreSQL",
    "EnableAutoInitialization": true,
    "InitializationDelaySeconds": 10
  }
}
